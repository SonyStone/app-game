{
  "name": "@app-game/vite-plugin-markdown",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "src/client.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "default": "./dist/runtime.mjs"
    },
    "./client": "./src/client.d.ts"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean"
  },
  "peerDependencies": {
    "vite": "catalog:"
  },
  "dependencies": {
    "@app-game/vite-plugin-shiki": "workspace:*",
    "markdown-exit": "catalog:"
  },
  "devDependencies": {
    "tsdown": "^0.22.0"
  }
}
